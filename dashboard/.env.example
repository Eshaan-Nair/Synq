# SYNQ Dashboard Configuration
# v1.4.5+

# The URL where the SYNQ backend is running (default: http://localhost:3001)
VITE_BACKEND_URL=http://localhost:3001

# The secret key required by the backend (X-SYNQ-Secret)
# If the backend was installed via install.sh/bat, this was auto-generated in backend/.env
VITE_SYNQ_SECRET=
